# Copy to .env and edit. Never commit secrets.

# Django
DJANGO_SECRET_KEY=dev-insecure-change-me
DJANGO_DEBUG=false
DJANGO_ALLOWED_HOSTS=hackathonapi.cortextechnologies.net,localhost,127.0.0.1
# drf_spectacular /docs/ + /api/schema/. Prod overlay (docker-compose.prod.yml)
# flips this to false to remove the docs surface.
DJANGO_ENABLE_DOCS=true

# Postgres (matches docker-compose db service). Override POSTGRES_PASSWORD in
# a gitignored root .env for prod.
DATABASE_URL=postgres://cortex:cortex_pw@db:5432/cortex

# Normalizer service (separate teammate). Override per environment.
NORMALIZER_URL=http://normalizer:9000
NORMALIZER_TIMEOUT_S=20

# HTTP retry behavior when calling normalizer
NORMALIZER_MAX_RETRIES=2
NORMALIZER_RETRY_BACKOFF_S=0.5

# Safety: if true, /sort-ticket returns 500 when safety rule fails (loud).
# If false, the response is returned with human_review_required=true and a
# Soft-fail: a templated safe reply is returned with human_review_required=true
# (never a 500 on an otherwise-valid request). Flip to true only when debugging.
SAFETY_FAIL_LOUD=false

LOG_LEVEL=INFO