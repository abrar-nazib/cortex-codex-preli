  "ticket_id": "T10",
  "complaint": "I sent 3000 taka to the wrong number please help",
  "language": "en",
  "channel": "in_app_chat",
  "user_type": "customer",
  "transaction_history": []
}

# Expected: relevant_transaction_id=null, evidence_verdict=insufficient_data,
#           case_type=wrong_transfer (from complaint text),
#           department=dispute_resolution, severity=medium,
#           human_review=true (confidence likely < 0.5 due to insufficient_data,
#           OR insufficient_data + payment_failed → False but wrong_transfer
#           overrides → True). Conservative expected: human_review=true.

