    {"transaction_id": "TXN-B", "timestamp": "2026-04-13T10:00:00Z", "type": "cash_in",  "amount": 1000, "counterparty": "AGENT-1",    "status": "completed"},
    {"transaction_id": "TXN-C", "timestamp": "2026-04-13T14:00:00Z", "type": "transfer", "amount": 7500, "counterparty": "+8801799999999", "status": "completed"},
    {"transaction_id": "TXN-D", "timestamp": "2026-04-13T16:00:00Z", "type": "payment",  "amount": 200,  "counterparty": "MERCHANT-2", "status": "completed"},
    {"transaction_id": "TXN-E", "timestamp": "2026-04-13T18:00:00Z", "type": "transfer", "amount": 3000, "counterparty": "+8801811111111", "status": "completed"}
  ]
}

# Expected: relevant_transaction_id=TXN-C (only TXN with amount=7500),
#           evidence_verdict=consistent, case_type=wrong_transfer,
#           severity=high, department=dispute_resolution, human_review=true

