Content-Type: application/json

{
  "ticket_id": "T19",
  "complaint": "I got a phone call from someone asking for my PIN to unblock my account",
  "language": "en",
  "channel": "call_center",
  "user_type": "customer",
  "transaction_history": []
}

# Expected: case_type=phishing_or_social_engineering, severity=critical,
#           department=fraud_risk, human_review=true (forced by Stage 4
#           code, see stage4_safety.py:_force_human_review line ~155)

