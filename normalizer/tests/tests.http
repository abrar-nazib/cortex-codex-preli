#      valid enums, human_review=true (conservative fallback),
#      reason_codes contains "rules_fallback"
#   5. Restore real API key after test
POST http://localhost:8001/analyze-ticket
Content-Type: application/json

{
  "ticket_id": "T38",
  "complaint": "I sent 5000 taka to the wrong number this morning",
  "language": "en",
  "channel": "in_app_chat",
  "user_type": "customer",
  "transaction_history": [
    {"transaction_id": "TXN-T38", "timestamp": "2026-04-14T10:08:22Z", "type": "transfer", "amount": 5000, "counterparty": "+8801799999999", "status": "completed"}
